      <bpmn:serviceTask id="Activity_18acw7b" name="Throw  service request completed message" zeebe:modelerTemplate="ae.gov.adha.cba.bpm.ThrowMessage.v1" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/svg+xml;utf8,%3Csvg width=&#39;800px&#39; height=&#39;800px&#39; viewBox=&#39;0 0 24 24&#39; fill=&#39;none&#39; xmlns=&#39;http://www.w3.org/2000/svg&#39;%3E%3Cpath d=&#39;M1.60175 4.20114C2.14997 3.47258 3.02158 3 4 3H20C20.9784 3 21.85 3.47258 22.3982 4.20113L12 11.7635L1.60175 4.20114Z&#39; fill=&#39;%23000000&#39;/%3E%3Cpath d=&#39;M1 6.2365V18C1 19.6523 2.34772 21 4 21H20C21.6523 21 23 19.6523 23 18V6.23649L13.1763 13.381C12.475 13.891 11.525 13.891 10.8237 13.381L1 6.2365Z&#39; fill=&#39;%23000000&#39;/%3E%3C/svg%3E">
